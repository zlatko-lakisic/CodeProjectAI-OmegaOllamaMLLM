{
  "Modules": {
    "OmegaOllamaMultiModalLLM": {
      "Name": "Ollama MultiModal LLM by OmegaIT",
      "Version": "1.0.0",

      "PublishingInfo": {
        "Description": "Image and video description and VQA using Ollama with configurable vision models (default: Moondream). Supports images or video (samples frames, describes each, then summarizes). Requires Ollama installed and running.",
        "Category": "Computer Vision",
        "Stack": "Python, Ollama",
        "License": "MIT with Attribution",
        "LicenseUrl": "https://omega-it.solutions",
        "Author": "Zlatko Lakisic, OmegaIT LLC",
        "Homepage": "https://omega-it.solutions"
      },

      "LaunchSettings": {
        "AutoStart": false,
        "FilePath": "omega_ollama_multimodal_adapter.py",
        "Runtime": "python3.10",
        "RuntimeLocation": "Local",
        "PostStartPauseSecs": 1,
        "Queue": "vision_queue",
        "Parallelism": 0
      },

      "EnvironmentVariables": {
        "OLLAMA_VISION_MODEL": "moondream",
        "OLLAMA_VIDEO_INTERVAL_SEC": "8",
        "OLLAMA_VIDEO_MAX_FRAMES": "4"
      },

      "GpuOptions" : {
        "InstallGPU":            true,
        "EnableGPU":             true,     // Will be coerced to false if InstallGPU = false
        "AcceleratorDeviceName": null,     // = default
        "HalfPrecision":         "enable"  // 'Force', 'Enable', 'Disable': whether to force on, allow, or disable half-precision ops
      },

      "UIElements": {
        "Menus": [{
          "Label": "Vision model",
          "Options": [
            { "Label": "Moondream (default, small ~1.8B)", "Setting": "OLLAMA_VISION_MODEL", "Value": "moondream" },
            { "Label": "LLaVA 7B", "Setting": "OLLAMA_VISION_MODEL", "Value": "llava" },
            { "Label": "LLaVA 13B", "Setting": "OLLAMA_VISION_MODEL", "Value": "llava:13b" },
            { "Label": "LLaVA 34B", "Setting": "OLLAMA_VISION_MODEL", "Value": "llava:34b" },
            { "Label": "Llama 3.2 Vision 11B", "Setting": "OLLAMA_VISION_MODEL", "Value": "llama3.2-vision:11b" },
            { "Label": "Llama 3.2 Vision 90B", "Setting": "OLLAMA_VISION_MODEL", "Value": "llama3.2-vision:90b" },
            { "Label": "LLaVA Llama3 8B", "Setting": "OLLAMA_VISION_MODEL", "Value": "llava-llama3:8b" },
            { "Label": "MiniCPM-V 8B", "Setting": "OLLAMA_VISION_MODEL", "Value": "minicpm-v:8b" },
            { "Label": "Qwen 2.5 VL 7B", "Setting": "OLLAMA_VISION_MODEL", "Value": "qwen2.5-vl:7b" }
          ]
        }]
      },

      "InstallOptions" : {
        "Platforms": [ "all" ],     // The platforms this module can and cannot be installed on
        "ModuleReleases": [         // Which server version is compatible with each version of this module.
          { "ModuleVersion": "1.0.0", "ServerVersionRange": [ "2.6.1", ""     ], "ReleaseDate": "2023-02-14", "ReleaseNotes": "Initial Release", "Importance": "Major" }
        ]
      },

      "RouteMaps": [
        {
          "Name": "Describe image (omega-ollama)",
          "Route": "vision/omega-ollama/describe-image",
          "Method": "POST",
          "Command": "describe-image",
          "Description": "Describe an image or answer a question about it. Use describe-video for video files.",
          "Inputs": [
            { "Name": "image", "Type": "File", "Description": "Image file (e.g. .jpg, .png)." },
            { "Name": "prompt", "Type": "String", "Description": "Optional prompt.", "DefaultValue": "Describe this image in a few sentences." }
          ],
          "Outputs": [
            { "Name": "success", "Type": "Boolean", "Description": "True if the request succeeded." },
            { "Name": "description", "Type": "String", "Description": "The model's description or answer." },
            { "Name": "error", "Type": "String", "Description": "Error message if success is false." }
          ]
        },
        {
          "Name": "Describe video (omega-ollama)",
          "Route": "vision/omega-ollama/describe-video",
          "Method": "POST",
          "Command": "describe-video",
          "Description": "Describe a video: samples frames, describes each, then summarizes. Use describe-image for image files.",
          "Inputs": [
            { "Name": "video", "Type": "File", "Description": "Video file (e.g. .mp4, .webm)." },
            { "Name": "prompt", "Type": "String", "Description": "Optional prompt for each frame.", "DefaultValue": "Describe this image in a few sentences." }
          ],
          "Outputs": [
            { "Name": "success", "Type": "Boolean", "Description": "True if the request succeeded." },
            { "Name": "description", "Type": "String", "Description": "Summary of the video." },
            { "Name": "error", "Type": "String", "Description": "Error message if success is false." }
          ]
        },
        {
          "Name": "Describe image (Explorer)",
          "Route": "OmegaOllamaMultiModalLLM/describe-image",
          "Method": "POST",
          "Command": "describe-image",
          "Description": "Image only. Use describe-video for video.",
          "Inputs": [
            { "Name": "image", "Type": "File", "Description": "Image file." },
            { "Name": "prompt", "Type": "String", "Description": "Optional prompt.", "DefaultValue": "Describe this image in a few sentences." }
          ],
          "Outputs": [
            { "Name": "success", "Type": "Boolean" },
            { "Name": "description", "Type": "String" },
            { "Name": "error", "Type": "String" }
          ]
        },
        {
          "Name": "Describe video (Explorer)",
          "Route": "OmegaOllamaMultiModalLLM/describe-video",
          "Method": "POST",
          "Command": "describe-video",
          "Description": "Video only. Use describe-image for images.",
          "Inputs": [
            { "Name": "video", "Type": "File", "Description": "Video file." },
            { "Name": "prompt", "Type": "String", "Description": "Optional prompt.", "DefaultValue": "Describe this image in a few sentences." }
          ],
          "Outputs": [
            { "Name": "success", "Type": "Boolean" },
            { "Name": "description", "Type": "String" },
            { "Name": "error", "Type": "String" }
          ]
        },
        {
          "Name": "OpenAI chat completions (LLM Vision)",
          "Route": "chat/completions",
          "Method": "POST",
          "Command": "chat-completions",
          "Description": "OpenAI-compatible vision endpoint for LLM Vision (Home Assistant). Send JSON body with messages (image_url + text) and optional model.",
          "Inputs": [
            { "Name": "messages", "Type": "String", "Description": "JSON array of messages (OpenAI format)." },
            { "Name": "model", "Type": "String", "Description": "Optional model name.", "DefaultValue": "omega-ollama" }
          ],
          "Outputs": [
            { "Name": "choices", "Type": "String", "Description": "OpenAI-style choices array." },
            { "Name": "model", "Type": "String", "Description": "Model used." }
          ]
        }
      ]
    }
  }
}
